      "source": [
        "# 台形の面積を計算するプログラム\n",
        "\n",
        "# 各辺の値を変数に代入\n",
        "top = 10      # 上辺 (cm)\n",
        "bottom = 20   # 下辺 (cm)\n",
        "height = 5    # 高さ (cm)\n",
        "\n",
        "# 台形の面積を計算して変数に代入\n",
        "area = (top + bottom) * height / 2\n",
        "\n",
        "# 結果を「◯◯cm²」の形式で出力\n",
        "print(str(area) + \"cm²\")"
      ]
    }
  ]
