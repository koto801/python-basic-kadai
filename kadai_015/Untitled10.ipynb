      "source": [
        "# Humanクラスの定義\n",
        "class Human:\n",
        "    def __init__(self, name, age):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "\n",
        "    def printinfo(self):\n",
        "        print(self.name)\n",
        "        print(self.age)\n",
        "\n",
        "# インスタンスを変数に代入\n",
        "person = Human(\"田中太郎\", 25)\n",
        "\n",
        "# メソッドを使って出力\n",
        "person.printinfo()"
      ]
    }
  ]
}